{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist-be/backend/server",
    "rootDir": "./src/backend",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/backend/webserver/**/*.ts", "src/backend/shared/**/*.ts"],
  "exclude": ["node_modules"]
}
