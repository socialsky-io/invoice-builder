{
  "name": "invoice-builder",
  "private": true,
  "version": "2.5.0",
  "type": "module",
  "description": "Invoice and quotation builder desktop app with PDF export, designed for small businesses and freelancers. Create, manage, and export invoices and quotes easily using a local database in an Electron-based app.",
  "author": "piratuks",
  "keywords": [
    "invoice",
    "quotation",
    "quote",
    "billing",
    "pdf-export",
    "pdf-generation",
    "business-management",
    "finance",
    "accounting",
    "desktop-app",
    "electron",
    "local-database",
    "invoice-builder",
    "quotation-builder",
    "billing-software",
    "business-software",
    "document-generation",
    "e-invoices",
    "peppol",
    "ubl",
    "xrechnung"
  ],
  "bugs": {
    "url": "https://github.com/piratuks/invoice-builder/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/piratuks/invoice-builder.git"
  },
  "license": "MIT",
  "scripts": {
    "docker:build": "docker build -t invoice-builder .",
    "docker:backup-data": "node scripts/backup-data.cjs",
    "docker:remove-database": "node scripts/remove-db.cjs",
    "docker:list-databases": "docker exec backend ls /data",
    "docker:list-databases:single": "docker exec invoice-builder ls /data",
    "docker:compose:up:single": "docker compose -f docker-compose.standalone.yml up -d",
    "docker:compose:pull": "docker compose pull",
    "docker:compose:build": "docker compose up -d --build",
    "docker:compose:up": "docker compose up -d",
    "docker:compose:down": "docker compose down -d",
    "dev": "npm run dev:clean:backend && concurrently \"npm:dev:react\" \"npm:dev:preload\" \"npm:dev:migrations\" \"npm:dev:electron\" \"npm:dev:electron:start:wait\"",
    "dev:clean:backend": "rimraf dist-be/backend",
    "dev:webserver": "set TS_NODE_PROJECT=tsconfig.webserver.json && npx tsx --watch src/backend/webserver/main.ts",
    "dev:fe": "concurrently \"npm:dev:react\" \"npm:dev:preload\" \"npm:dev:migrations\"",
    "dev:preload": "vite build --config vite.preload.config.ts --watch",
    "dev:react": "vite",
    "dev:electron:start:wait": "wait-on dist-be/backend/main/main.cjs && npm run dev:electron:start",
    "dev:electron:start": "electronmon dist-be/backend/main/main.cjs --exit",
    "dev:electron": "vite build --config vite.electron.config.ts --watch",
    "dev:migrations": "vite build --config vite.migrations.config.ts --watch",
    "build": "npm run build:react && npm run build:preload && npm run build:migrations && npm run build:electron",
    "build:webserver": "tsc -p tsconfig.webserver.json && node scripts/copy-webserver-package.js",
    "build:fe": "npm run build:react && npm run build:preload && npm run build:migrations && npm run build:webserver",
    "build:react": "vite build",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:migrations": "vite build --config vite.migrations.config.ts",
    "build:electron": "vite build --config vite.electron.config.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "lint:fix": "eslint --fix .",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "sort:i18n": "node scripts/sort-i18n.js",
    "package": "npm run build && electron-builder --win --x64",
    "release:win": "npm run build && electron-builder --win --x64 --publish always",
    "release:linux": "npm run build && electron-builder --linux --publish always",
    "release:mac": "npm run build && electron-builder --mac --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/x-date-pickers": "^8.27.2",
    "@react-pdf/renderer": "^4.3.2",
    "@reduxjs/toolkit": "^2.11.2",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.2",
    "file-saver": "^2.0.5",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "mui-color-input": "^7.0.0",
    "multer": "^2.1.1",
    "pako": "^2.1.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^16.5.6",
    "react-image-crop": "^11.0.10",
    "react-number-format": "^5.4.4",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "recharts": "^3.8.0",
    "sqlite3": "^5.1.7",
    "tsx": "^4.21.0",
    "uuid": "^13.0.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@emotion/jest": "^11.14.2",
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "@types/pako": "^2.0.4",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/redux-mock-store": "^1.5.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "baseline-browser-mapping": "^2.10.0",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "prettier": "^3.8.1",
    "redux-mock-store": "^1.5.5",
    "sort-json": "^2.0.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.2.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "overrides": {
    "ajv": "6.12.6",
    "ajv-keywords": "3.5.2",
    "tar": "^7.5.9",
    "minimatch": "^10.2.1"
  }
}