{
  "name": "invoice-builder",
  "private": true,
  "version": "1.2.2",
  "type": "module",
  "description": "Invoice and quotation builder desktop app with PDF export, designed for small businesses and freelancers. Create, manage, and export invoices and quotes easily using a local database in an Electron-based app.",
  "author": "piratuks",
  "keywords": [
    "invoice",
    "quotation",
    "quote",
    "billing",
    "pdf-export",
    "pdf-generation",
    "business-management",
    "finance",
    "accounting",
    "desktop-app",
    "electron",
    "local-database",
    "invoice-builder",
    "quotation-builder",
    "billing-software",
    "business-software",
    "document-generation"
  ],
  "bugs": {
    "url": "https://github.com/piratuks/invoice-builder/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/piratuks/invoice-builder.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm:dev:react\" \"npm:dev:preload\" \"npm:dev:migrations\" \"npm:dev:electron\" \"npm:dev:electron:start:wait\"",
    "dev:preload": "vite build --config vite.preload.config.ts --watch",
    "dev:react": "vite",
    "dev:electron:start:wait": "wait-on dist-electron/main/main.cjs && npm run dev:electron:start",
    "dev:electron:start": "electronmon dist-electron/main/main.cjs --exit",
    "dev:electron": "vite build --config vite.electron.config.ts --watch",
    "dev:migrations": "vite build --config vite.migrations.config.ts --watch",
    "build": "npm run build:react && npm run build:preload && npm run build:migrations && npm run build:electron",
    "build:react": "vite build",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:migrations": "vite build --config vite.migrations.config.ts",
    "build:electron": "vite build --config vite.electron.config.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "lint:fix": "eslint --fix .",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "sort:i18n": "node scripts/sort-i18n.js",
    "package": "npm run build && electron-builder --win --x64",
    "release:win": "npm run build && electron-builder --win --x64 --publish always",
    "release:linux": "npm run build && electron-builder --linux --publish always",
    "release:mac": "npm run build && electron-builder --mac --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@mui/x-date-pickers": "^8.19.0",
    "@react-pdf/renderer": "^4.3.1",
    "@reduxjs/toolkit": "^2.10.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.6.2",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "i18next": "^25.6.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "mui-color-input": "^7.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.0.0",
    "react-i18next": "^16.2.4",
    "react-image-crop": "^11.0.10",
    "react-number-format": "^5.4.4",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.5",
    "recharts": "^3.6.0",
    "sqlite3": "^5.1.7",
    "uuid": "^13.0.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@emotion/jest": "^11.13.0",
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/redux-mock-store": "^1.5.0",
    "@types/sqlite3": "^5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "electron": "^39.1.1",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "electronmon": "^2.0.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.15.1",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.0.0",
    "msw": "^2.7.3",
    "prettier": "^3.5.0",
    "redux-mock-store": "^1.5.5",
    "sort-json": "^2.0.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2",
    "vite-plugin-static-copy": "^3.1.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.6",
    "wait-on": "^9.0.3"
  },
  "msw": {
    "workerDirectory": "public"
  }
}